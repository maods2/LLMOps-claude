# LLM Stack – Environment Variables
# Copy to .env and customise before running.

# ── Model ──────────────────────────────────────────────────
MODEL_PATH=./checkpoints/pretrain/final
MODEL_VERSION=v0.1.0

# ── Training ───────────────────────────────────────────────
DTYPE=bfloat16
TRAINING_STAGE=pretrain

# ── Serving ────────────────────────────────────────────────
USE_VLLM=true
MAX_SEQ_LEN=512
GPU_MEM_UTIL=0.85
SERVING_PORT=8000
METRICS_PORT=8090

# ── Docker / Compose ───────────────────────────────────────
HOST_CHECKPOINTS=./checkpoints
HOST_DATA_CACHE=./data_cache
HOST_LOGS=./logs

# ── Observability ──────────────────────────────────────────
LOG_LEVEL=INFO
JSON_LOGS=true
ENVIRONMENT=production
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── AWS (optional – for S3 checkpoint sync) ────────────────
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_CHECKPOINT_BUCKET=my-llm-checkpoints
